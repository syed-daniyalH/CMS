# Frontend environment variables for local development and Vercel

# Backend API base URL
NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# Optional GraphQL endpoint. Leave pointing to the backend unless you replace it.
NEXT_PUBLIC_GRAPHQL_URL=https://your-backend-domain.com/graphql

# Public image/CDN base used by legacy image paths in the UI
NEXT_PUBLIC_IMAGE_URL=https://your-public-image-cdn.example/

# Public R2 base used by newer upload flows
NEXT_PUBLIC_IMAGE_URL_R2=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev/

# Branding / app name key used in the UI
NEXT_PUBLIC_APP_NAME=indraaj

# Set to false in production
NEXT_PUBLIC_USE_MOCK_AUTH=false
